      "parameters": {
        "jsCode": "const items = $input.all();\n\nfunction extractYouTubeVideoId(input) {\n  if (!input || typeof input !== 'string') return null;\n\n  const text = input.trim();\n\n  const patterns = [\n    /youtu\\.be\\/([a-zA-Z0-9_-]{11})/,\n    /youtube\\.com\\/watch\\?v=([a-zA-Z0-9_-]{11})/,\n    /youtube\\.com\\/shorts\\/([a-zA-Z0-9_-]{11})/,\n    /youtube\\.com\\/embed\\/([a-zA-Z0-9_-]{11})/,\n    /(?:^|[^a-zA-Z0-9_-])([a-zA-Z0-9_-]{11})(?:$|[^a-zA-Z0-9_-])/\n  ];\n\n  for (const pattern of patterns) {\n    const match = text.match(pattern);\n    if (match?.[1]) return match[1];\n  }\n\n  return null;\n}\n\nreturn items.map(item => {\n  const chatInput = item.json.chatInput || item.json.text || item.json.message || '';\n  const videoId = extractYouTubeVideoId(chatInput);\n\n  if (!videoId) {\n    throw new Error(`Invalid YouTube source. video_id tidak ditemukan dari input: ${chatInput}`);\n  }\n\n  return {\n    json: {\n      ...item.json,\n      source: `https://youtu.be/${videoId}`,\n      video_id: videoId,\n      original_input: chatInput\n    }\n  };\n});"
      },
