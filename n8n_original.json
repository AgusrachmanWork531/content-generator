      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const body = item.json.body || item.json;\n  const artifact = body.artifact_status || {};\n\n  // For watermark step, verify watermarked file exists\n  if (body.step === 'watermark') {\n    const watermarkedCount = artifact.watermarked_count || 0;\n    \n    if (watermarkedCount <= 0) {\n      throw new Error(`Watermark final video tidak ditemukan. artifact_status: ${JSON.stringify(artifact)}`);\n    }\n    \n    if (artifact.missing_expected_artifact) {\n      throw new Error(`Watermark artifact missing. Response: ${JSON.stringify(body)}`);\n    }\n  }\n\n  return item;\n});"
